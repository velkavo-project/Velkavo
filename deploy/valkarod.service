[Unit]
Description=Valkavo Daemon
After=network.target

[Service]
Type=forking
User=valkavo
ExecStart=/usr/local/bin/valkarod --config-file /etc/valkavo/valkavo.conf --detach
ExecStop=/usr/local/bin/valkarod --config-file /etc/valkavo/valkavo.conf stop
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
