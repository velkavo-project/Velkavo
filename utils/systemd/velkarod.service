[Unit]
Description=Velkavo Full Node
After=network-online.target

[Service]
User=velkavo
Group=velkavo
WorkingDirectory=~
StateDirectory=velkavo
LogsDirectory=velkavo

Type=simple
ExecStart=/usr/bin/velkarod --config-file /etc/velkarod.conf --non-interactive
StandardOutput=null
StandardError=null

Restart=always

[Install]
WantedBy=multi-user.target
